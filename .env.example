# Server URL for PDF B&W conversion (Render cloud URL after deployment)
# EXPO_PUBLIC_SERVER_URL=https://ntr-server.onrender.com
# Secret key must match CONVERT_API_KEY set in Render environment variables
# EXPO_PUBLIC_CONVERT_API_KEY=your_secret_key_here

# Get a free API key from https://aistudio.google.com/apikey
# If you see "quota exceeded" (429), enable billing or create a key in a new project.
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
# Optional: gemini-2.0-flash | gemini-2.5-flash | gemini-1.5-flash
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# Google OAuth Web Client ID (from Firebase Console > Authentication > Google > Web client ID)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id_here
